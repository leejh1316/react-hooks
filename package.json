{
  "name": "react-hooks",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter demo dev",
    "build": "pnpm run build:packages && pnpm --filter demo build",
    "preview": "pnpm run build:packages && pnpm --filter demo preview",
    "build:packages": "pnpm --filter \"./packages/*\" build",
    "build:use-focus-trap": "pnpm --filter use-focus-trap build",
    "build:use-roving-focus": "pnpm --filter use-roving-focus build"
  },
  "devDependencies": {
    "typescript": "~6.0.2"
  }
}
